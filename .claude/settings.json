{
  "permissions": {
    "allow": [
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(git -C /Users/myori/Public/workspace/autoflow add .claude/commands/issue-start.md .claude/settings.json)",
      "Bash(git -C /Users/myori/Public/workspace/autoflow status)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "GitHub 이슈 상태 확인 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-write-lint.sh",
            "timeout": 30,
            "statusMessage": "Lint 검사 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop.sh",
            "timeout": 15,
            "statusMessage": "이슈 상태 업데이트 중..."
          }
        ]
      }
    ]
  }
}
